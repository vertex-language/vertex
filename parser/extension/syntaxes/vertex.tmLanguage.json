{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vertex",
  "scopeName": "source.vtx",
  "fileTypes": ["vs"],

  "patterns": [
    { "include": "#comment" },
    { "include": "#multiline-string" },
    { "include": "#string" },
    { "include": "#char-literal" },
    { "include": "#directive" },
    { "include": "#function-decl" },
    { "include": "#type-decl" },
    { "include": "#keywords" },
    { "include": "#postfix" },
    { "include": "#support-types" },
    { "include": "#constants" },
    { "include": "#numeric-literal" },
    { "include": "#operator" }
  ],

  "repository": {

    "comment": {
      "name": "comment.line.double-slash.vertex",
      "match": "//.*$"
    },

    "multiline-string": {
      "name": "string.quoted.backtick.vertex",
      "begin": "`",
      "end": "`"
    },

    "string": {
      "name": "string.quoted.double.vertex",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.vertex",
          "match": "\\\\[nrtbf\"\\\\]"
        },
        {
          "name": "invalid.illegal.escape.vertex",
          "match": "\\\\."
        }
      ]
    },

    "char-literal": {
      "name": "string.quoted.single.vertex",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.vertex",
          "match": "\\\\[nrtbf'\\\\]"
        },
        {
          "name": "invalid.illegal.escape.vertex",
          "match": "\\\\."
        }
      ]
    },

    "directive": {
      "patterns": [
        {
          "comment": "package declaration — captures keyword + namespace name",
          "match": "^(\\s*)(package)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.other.package.vertex" },
            "4": { "name": "entity.name.namespace.vertex" }
          }
        },
        {
          "comment": "build tag — captures keyword + tag identifier",
          "match": "^(\\s*)(build)(\\s+)([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "2": { "name": "keyword.other.build.vertex" },
            "4": { "name": "constant.language.build-tag.vertex" }
          }
        }
      ]
    },

    "function-decl": {
      "patterns": [
        {
          "comment": "Associated function with receiver: func (recv: T) name( or <",
          "match": "\\b(func)\\b\\s*\\([^)]*\\)\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.function.vertex" },
            "2": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "comment": "Named function without receiver: func name( or <",
          "match": "\\b(func)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)(?=\\s*[<(])",
          "captures": {
            "1": { "name": "keyword.declaration.function.vertex" },
            "2": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "comment": "Anonymous function expression or function type: func(",
          "match": "\\b(func)\\b(?=\\s*\\()",
          "captures": {
            "1": { "name": "keyword.declaration.function.vertex" }
          }
        }
      ]
    },

    "type-decl": {
      "patterns": [
        {
          "match": "\\b(struct)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.struct.vertex" },
            "2": { "name": "entity.name.type.struct.vertex" }
          }
        },
        {
          "match": "\\b(class)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.class.vertex" },
            "2": { "name": "entity.name.type.class.vertex" }
          }
        },
        {
          "match": "\\b(enum)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.enum.vertex" },
            "2": { "name": "entity.name.type.enum.vertex" }
          }
        },
        {
          "match": "\\b(type)\\b\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.vertex" },
            "2": { "name": "entity.name.type.alias.vertex" }
          }
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Control flow",
          "name": "keyword.control.vertex",
          "match": "\\b(if|else|for|in|while|switch|case|default|return|break|continue|fallthrough|defer)\\b"
        },
        {
          "comment": "Import",
          "name": "keyword.control.import.vertex",
          "match": "\\bimport\\b"
        },
        {
          "comment": "Binding modifiers: let / var / weak",
          "name": "storage.modifier.vertex",
          "match": "\\b(let|var|weak)\\b"
        },
        {
          "comment": "Const pointer modifier (*const T)",
          "name": "storage.modifier.const.vertex",
          "match": "\\bconst\\b"
        },
        {
          "comment": "Execution / test qualifiers",
          "name": "keyword.other.qualifier.vertex",
          "match": "\\b(async|thread|process|gpu|test)\\b"
        },
        {
          "comment": "Channel and map type keywords",
          "name": "storage.type.builtin.vertex",
          "match": "\\b(chan|map)\\b"
        },
        {
          "comment": "Inline assembly block",
          "name": "keyword.other.asm.vertex",
          "match": "\\basm\\b"
        },
        {
          "comment": "ASM constraint keywords: in is reused from control flow",
          "name": "keyword.other.asm-constraint.vertex",
          "match": "\\b(inout|out|clobber)\\b"
        },
        {
          "comment": "Raw pointer reinterpret cast",
          "name": "keyword.operator.cast.vertex",
          "match": "\\breinterpret\\b"
        }
      ]
    },

    "postfix": {
      "patterns": [
        {
          "comment": "Execution model postfixes: .await() .spawn() .fork() .dispatch() .channel() .new() .delete() .try()",
          "match": "\\.(await|spawn|fork|dispatch|channel|new|delete|try)(?=\\s*\\()",
          "captures": {
            "1": { "name": "support.function.builtin.postfix.vertex" }
          }
        },
        {
          "comment": "Built-in array / map / channel methods and properties",
          "match": "\\.(push|pop|shift|unshift|length|find|findIndex|indexOf|includes|sort|reverse|fill|map|filter|slice|concat|forEach|send|receive|trySend|tryReceive|close|rawValue)\\b",
          "captures": {
            "1": { "name": "support.function.builtin.vertex" }
          }
        }
      ]
    },

    "support-types": {
      "patterns": [
        {
          "comment": "Scalar primitives — width-specific names listed before short aliases so int8 beats int",
          "name": "support.type.primitive.vertex",
          "match": "\\b(int8|int16|int32|int64|uint8|uint16|uint32|uint64|float64|int|uint|float|bool|char|string|void)\\b"
        },
        {
          "comment": "Result / error-handling types",
          "name": "support.type.result.vertex",
          "match": "\\b(Result|Ok|Err|Expected)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.true.vertex",
          "match": "\\btrue\\b"
        },
        {
          "name": "constant.language.boolean.false.vertex",
          "match": "\\bfalse\\b"
        },
        {
          "name": "constant.language.nil.vertex",
          "match": "\\bnil\\b"
        }
      ]
    },

    "numeric-literal": {
      "patterns": [
        {
          "comment": "Hex float: 0xFp2, 0xC.3p0 — must precede hex int",
          "name": "constant.numeric.float.hex.vertex",
          "match": "\\b0[xX][0-9a-fA-F]+(?:\\.[0-9a-fA-F]+)?[pP][+\\-]?[0-9]+\\b"
        },
        {
          "comment": "Decimal float with exponent: 1.25e2, 1.25E-2, 1e10 — must precede decimal int",
          "name": "constant.numeric.float.decimal.vertex",
          "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?[eE][+\\-]?[0-9]+\\b"
        },
        {
          "comment": "Decimal float with dot: 3.14, 1_000.000_1 — must precede decimal int",
          "name": "constant.numeric.float.decimal.vertex",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "comment": "Hex integer: 0xFF, 0xBadFace, 0x0123_4567",
          "name": "constant.numeric.integer.hex.vertex",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "comment": "Octal integer: 0o52",
          "name": "constant.numeric.integer.octal.vertex",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "comment": "Binary integer: 0b101010",
          "name": "constant.numeric.integer.binary.vertex",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "comment": "Decimal integer: 42, 1_000_000",
          "name": "constant.numeric.integer.decimal.vertex",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "operator": {
      "comment": "All patterns ordered so longer / higher-priority tokens beat prefixes at the same position.",
      "patterns": [
        {
          "comment": "Return-type arrow: ->",
          "name": "keyword.operator.arrow.vertex",
          "match": "->"
        },
        {
          "comment": "Range operators: ..< and ...",
          "name": "keyword.operator.range.vertex",
          "match": "\\.\\.<|\\.\\.\\."
        },
        {
          "comment": "Overflow arithmetic: &+ &- &*  — before plain & and arithmetic",
          "name": "keyword.operator.overflow.vertex",
          "match": "&[+\\-*]"
        },
        {
          "comment": "Identity equality: === !==  — before == and !=",
          "name": "keyword.operator.identity.vertex",
          "match": "[!=]=="
        },
        {
          "comment": "Nil-coalescing: ??",
          "name": "keyword.operator.nil-coalescing.vertex",
          "match": "\\?\\?"
        },
        {
          "comment": "Logical: && ||  — before single & and |",
          "name": "keyword.operator.logical.vertex",
          "match": "&&|\\|\\|"
        },
        {
          "comment": "Compound assignment: += -= *= /= %=  — before plain arithmetic",
          "name": "keyword.operator.assignment.compound.vertex",
          "match": "[+\\-*/%]="
        },
        {
          "comment": "Equality / inequality / LE / GE: == != <= >=  — before plain < >",
          "name": "keyword.operator.comparison.vertex",
          "match": "[=!<>]="
        },
        {
          "comment": "Bitwise shift: << >>  — before plain < >",
          "name": "keyword.operator.bitwise.shift.vertex",
          "match": "<<|>>"
        },
        {
          "comment": "Logical NOT: !  — not followed by = (which would be != already matched)",
          "name": "keyword.operator.logical.not.vertex",
          "match": "!(?!=)"
        },
        {
          "comment": "Bitwise: ~ | ^  and & in address-of / bitwise-AND position",
          "name": "keyword.operator.bitwise.vertex",
          "match": "[~|^]|&(?![+\\-*&])"
        },
        {
          "comment": "Arithmetic: + - * / %",
          "name": "keyword.operator.arithmetic.vertex",
          "match": "[+\\-*/%]"
        },
        {
          "comment": "Less-than / greater-than (standalone comparison or generic bracket)",
          "name": "keyword.operator.comparison.vertex",
          "match": "[<>]"
        },
        {
          "comment": "Assignment: =  — not followed by = (which would be == already matched)",
          "name": "keyword.operator.assignment.vertex",
          "match": "=(?!=)"
        },
        {
          "comment": "Optional / ternary: ?",
          "name": "keyword.operator.optional.vertex",
          "match": "\\?"
        }
      ]
    }

  }
}