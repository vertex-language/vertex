{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vertex",
  "scopeName": "source.vtx",
  "fileTypes": ["vs"],
  "patterns": [
    { "include": "#build_tag" },
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#result_types" },
    { "include": "#boolean_nil" },
    { "include": "#numeric_literals" },
    { "include": "#string_multiline" },
    { "include": "#string_literal" },
    { "include": "#func_decl" },
    { "include": "#receiver_decl" },
    { "include": "#type_annotations" },
    { "include": "#asm_block" },
    { "include": "#postfix_intrinsics" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {

    "build_tag": {
      "comment": "§45 — build <tag> file-level directive",
      "match": "^\\s*(build)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*$",
      "captures": {
        "1": { "name": "keyword.other.build.vertex" },
        "2": { "name": "entity.name.tag.build.vertex" }
      }
    },

    "comments": {
      "patterns": [
        {
          "comment": "Line comment",
          "match": "//.*$",
          "name": "comment.line.double-slash.vertex"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Control flow",
          "match": "\\b(if|else|for|in|while|switch|case|default|return|break|continue|fallthrough|defer)\\b",
          "name": "keyword.control.vertex"
        },
        {
          "comment": "Declaration keywords",
          "match": "\\b(func|let|var|weak|struct|class|enum|type|import|package|build|asm)\\b",
          "name": "keyword.declaration.vertex"
        },
        {
          "comment": "Concurrency qualifiers",
          "match": "\\b(async|thread|process|gpu)\\b",
          "name": "keyword.other.concurrency.vertex"
        },
        {
          "comment": "Type-level keywords",
          "match": "\\b(chan|map)\\b",
          "name": "keyword.other.type.vertex"
        },
        {
          "comment": "const keyword — only valid in *const T position",
          "match": "\\b(const)\\b",
          "name": "keyword.other.const.vertex"
        },
        {
          "comment": "Inline-asm constraint keywords",
          "match": "\\b(inout|out|clobber)\\b",
          "name": "keyword.other.asm-constraint.vertex"
        }
      ]
    },

    "result_types": {
      "comment": "§38.3 — Result, Ok, Err are promoted keywords",
      "patterns": [
        {
          "match": "\\b(Result)\\s*\\(",
          "captures": {
            "1": { "name": "keyword.other.result.vertex" }
          }
        },
        {
          "match": "\\b(Ok|Err)\\b",
          "name": "keyword.other.result-variant.vertex"
        }
      ]
    },

    "boolean_nil": {
      "match": "\\b(true|false|nil)\\b",
      "name": "constant.language.vertex"
    },

    "numeric_literals": {
      "patterns": [
        {
          "comment": "Hex float — must come before hex int (maximal munch)",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(\\.[0-9a-fA-F]+)?[pP][+\\-]?[0-9]+\\b",
          "name": "constant.numeric.float.hex.vertex"
        },
        {
          "comment": "Hex integer",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b",
          "name": "constant.numeric.integer.hex.vertex"
        },
        {
          "comment": "Octal integer",
          "match": "\\b0[oO][0-7][0-7_]*\\b",
          "name": "constant.numeric.integer.octal.vertex"
        },
        {
          "comment": "Binary integer",
          "match": "\\b0[bB][01][01_]*\\b",
          "name": "constant.numeric.integer.binary.vertex"
        },
        {
          "comment": "Decimal float with fraction and optional exponent",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+\\-]?[0-9]+)?\\b",
          "name": "constant.numeric.float.decimal.vertex"
        },
        {
          "comment": "Decimal float with exponent only (no dot)",
          "match": "\\b[0-9][0-9_]*[eE][+\\-]?[0-9]+\\b",
          "name": "constant.numeric.float.decimal.vertex"
        },
        {
          "comment": "Decimal integer",
          "match": "\\b[0-9][0-9_]*\\b",
          "name": "constant.numeric.integer.decimal.vertex"
        }
      ]
    },

    "string_multiline": {
      "comment": "§3 — backtick multiline string, no escape processing",
      "begin": "`",
      "end": "`",
      "name": "string.quoted.backtick.vertex"
    },

    "string_literal": {
      "comment": "§1 — double-quoted string / char literal",
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.vertex",
      "patterns": [
        {
          "match": "\\\\[nrtbf\"\\\\]",
          "name": "constant.character.escape.vertex"
        },
        {
          "match": "\\\\.",
          "name": "invalid.illegal.escape.vertex"
        }
      ]
    },

    "func_decl": {
      "comment": "Named function declaration — captures qualifier, name, generic params",
      "patterns": [
        {
          "comment": "func with receiver — func (recv: Type) name<T>(...)",
          "match": "\\b(func)\\b",
          "name": "keyword.declaration.func.vertex"
        },
        {
          "comment": "Function name following closing paren of receiver or standalone func keyword",
          "match": "(?<=\\))\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=<|\\()",
          "captures": {
            "1": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "comment": "Function name immediately after 'func ' with no receiver",
          "match": "(?<=\\bfunc)\\s+(?!\\()([A-Za-z_][A-Za-z0-9_]*)\\s*(?=<|\\()",
          "captures": {
            "1": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "comment": "Generic type params <T, U>",
          "match": "<([A-Za-z_][A-Za-z0-9_]*(?:\\s*,\\s*[A-Za-z_][A-Za-z0-9_]*)*)>",
          "captures": {
            "1": { "name": "entity.name.type.parameter.vertex" }
          }
        }
      ]
    },

    "receiver_decl": {
      "comment": "§28 — receiver block (recv: Type) or (recv: *Type)",
      "begin": "(?<=\\bfunc)\\s*(\\()",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.receiver.begin.vertex" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.receiver.end.vertex" }
      },
      "patterns": [
        {
          "match": "([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": { "name": "variable.parameter.receiver.vertex" },
            "2": { "name": "punctuation.separator.colon.vertex" }
          }
        },
        { "include": "#type_annotations" }
      ]
    },

    "type_annotations": {
      "comment": "Type expressions in colon positions and return arrows",
      "patterns": [
        {
          "comment": "Return arrow ->",
          "match": "->",
          "name": "punctuation.separator.arrow.vertex"
        },
        {
          "comment": "Pointer type with optional const",
          "match": "\\*(const\\s+)?",
          "captures": {
            "0": { "name": "keyword.operator.pointer.vertex" },
            "1": { "name": "keyword.other.const.vertex" }
          }
        },
        {
          "comment": "Nullable suffix ?",
          "match": "(?<=[A-Za-z0-9_\\]\\)])\\?",
          "name": "keyword.operator.optional.vertex"
        },
        {
          "comment": "Built-in scalar types",
          "match": "\\b(int|int8|int16|int32|int64|uint|uint8|uint16|uint32|uint64|float|float64|bool|char|string|void)\\b",
          "name": "support.type.primitive.vertex"
        },
        {
          "comment": "Result type keyword in type position",
          "match": "\\b(Result)\\b",
          "name": "support.type.result.vertex"
        }
      ]
    },

    "asm_block": {
      "comment": "§47 — asm() expression",
      "begin": "\\b(asm)\\s*(\\()",
      "end": "\\)",
      "beginCaptures": {
        "1": { "name": "keyword.other.asm.vertex" },
        "2": { "name": "punctuation.definition.asm.begin.vertex" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.asm.end.vertex" }
      },
      "patterns": [
        {
          "comment": "Instruction strings",
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.asm-instruction.vertex"
        },
        {
          "comment": "Constraint keywords",
          "match": "\\b(in|inout|out|clobber)\\b",
          "name": "keyword.other.asm-constraint.vertex"
        },
        {
          "comment": "Register name strings",
          "match": "\"[^\"]*\"",
          "name": "string.quoted.double.asm-register.vertex"
        },
        {
          "include": "#identifiers"
        }
      ]
    },

    "postfix_intrinsics": {
      "comment": "§36,§39–§43 — postfix execution / lifecycle methods",
      "match": "\\.(?:await|spawn|fork|dispatch|channel|new|delete|try|send|receive|trySend|tryReceive|close|push|pop|shift|unshift|indexOf|includes|find|findIndex|sort|reverse|fill|map|filter|slice|concat|forEach|length|rawValue)\\b",
      "name": "support.function.builtin.vertex"
    },

    "operators": {
      "patterns": [
        {
          "comment": "Identity equality (class) — must precede ==",
          "match": "===|!==",
          "name": "keyword.operator.identity.vertex"
        },
        {
          "comment": "Overflow operators",
          "match": "&\\+|&-|&\\*",
          "name": "keyword.operator.overflow.vertex"
        },
        {
          "comment": "Nil coalescing",
          "match": "\\?\\?",
          "name": "keyword.operator.nil-coalescing.vertex"
        },
        {
          "comment": "Range operators",
          "match": "\\.\\.\\.|\\.\\.<",
          "name": "keyword.operator.range.vertex"
        },
        {
          "comment": "Comparison operators",
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.vertex"
        },
        {
          "comment": "Logical operators",
          "match": "&&|\\|\\||!",
          "name": "keyword.operator.logical.vertex"
        },
        {
          "comment": "Shift operators",
          "match": "<<|>>",
          "name": "keyword.operator.bitwise.shift.vertex"
        },
        {
          "comment": "Bitwise operators",
          "match": "[&|^~]",
          "name": "keyword.operator.bitwise.vertex"
        },
        {
          "comment": "Compound assignment operators",
          "match": "\\+=|-=|\\*=|/=|%=",
          "name": "keyword.operator.assignment.compound.vertex"
        },
        {
          "comment": "Assignment",
          "match": "(?<![=!<>])=(?!=)",
          "name": "keyword.operator.assignment.vertex"
        },
        {
          "comment": "Arithmetic operators",
          "match": "[+\\-*/%]",
          "name": "keyword.operator.arithmetic.vertex"
        },
        {
          "comment": "Address-of",
          "match": "&(?=[A-Za-z_])",
          "name": "keyword.operator.address-of.vertex"
        },
        {
          "comment": "Ternary operator characters",
          "match": "(?<![?])\\?(?![?])|(?<!:):(?!:)",
          "name": "keyword.operator.ternary.vertex"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "match": "\\.",
          "name": "punctuation.accessor.dot.vertex"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.vertex"
        },
        {
          "match": ":",
          "name": "punctuation.separator.colon.vertex"
        },
        {
          "match": ";",
          "name": "punctuation.terminator.vertex"
        },
        {
          "match": "\\{",
          "name": "punctuation.definition.block.begin.vertex"
        },
        {
          "match": "\\}",
          "name": "punctuation.definition.block.end.vertex"
        },
        {
          "match": "\\(",
          "name": "punctuation.definition.group.begin.vertex"
        },
        {
          "match": "\\)",
          "name": "punctuation.definition.group.end.vertex"
        },
        {
          "match": "\\[",
          "name": "punctuation.definition.array.begin.vertex"
        },
        {
          "match": "\\]",
          "name": "punctuation.definition.array.end.vertex"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "comment": "Type names — PascalCase heuristic",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
          "name": "entity.name.type.vertex"
        },
        {
          "comment": "General identifier",
          "match": "\\b[a-z_][A-Za-z0-9_]*\\b",
          "name": "variable.other.vertex"
        }
      ]
    }

  }
}