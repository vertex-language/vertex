{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Vertex",
  "scopeName": "source.vtx",
  "fileTypes": ["vs"],

  "patterns": [
    { "include": "#comments"          },
    { "include": "#strings"           },
    { "include": "#numeric-literals"  },
    { "include": "#language-constants"},
    { "include": "#declaration-names" },
    { "include": "#postfix-intrinsics"},
    { "include": "#keywords"          },
    { "include": "#primitive-types"   },
    { "include": "#special-types"     },
    { "include": "#operators"         }
  ],

  "repository": {

    "comments": {
      "patterns": [
        {
          "name": "comment.block.vertex",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.vertex" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.vertex"   } }
        },
        {
          "name": "comment.line.double-slash.vertex",
          "begin": "//",
          "end": "$",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.vertex" } }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "comment": "Raw backtick string — multiline, no escape processing",
          "name": "string.quoted.other.raw.vertex",
          "begin": "`",
          "end": "`",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.vertex" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.vertex"   } }
        },
        {
          "comment": "Double-quoted string — single line, backslash escapes",
          "name": "string.quoted.double.vertex",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.vertex" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.vertex"   } },
          "patterns": [
            {
              "name": "constant.character.escape.vertex",
              "match": "\\\\."
            }
          ]
        }
      ]
    },

    "numeric-literals": {
      "patterns": [
        {
          "comment": "Hex float  — 0xFp2  0xC.3p0  0xFp-2",
          "name": "constant.numeric.float.hex.vertex",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(\\.[0-9a-fA-F][0-9a-fA-F_]*)?[pP][+\\-]?[0-9][0-9_]*\\b"
        },
        {
          "comment": "Hex integer — 0xFF  0xBadFace",
          "name": "constant.numeric.integer.hex.vertex",
          "match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
        },
        {
          "comment": "Binary integer — 0b101010",
          "name": "constant.numeric.integer.binary.vertex",
          "match": "\\b0[bB][01][01_]*\\b"
        },
        {
          "comment": "Octal integer — 0o52",
          "name": "constant.numeric.integer.octal.vertex",
          "match": "\\b0[oO][0-7][0-7_]*\\b"
        },
        {
          "comment": "Decimal float with optional exponent — 3.14  1.25e-2",
          "name": "constant.numeric.float.decimal.vertex",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+\\-]?[0-9][0-9_]*)?\\b"
        },
        {
          "comment": "Decimal float exponent only — 1e2  1E-2",
          "name": "constant.numeric.float.decimal.vertex",
          "match": "\\b[0-9][0-9_]*[eE][+\\-]?[0-9][0-9_]*\\b"
        },
        {
          "comment": "Decimal integer — 42  1_000_000",
          "name": "constant.numeric.integer.decimal.vertex",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "language-constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.vertex",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.nil.vertex",
          "match": "\\bnil\\b"
        }
      ]
    },

    "declaration-names": {
      "comment": "Highlight the name that follows a declaration keyword. These patterns must come before the general keywords rule so the name capture fires in context.",
      "patterns": [
        {
          "comment": "Associated function — func (p: mut Point) methodName",
          "match": "\\b(func)\\s+(\\()\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)\\s*(mut\\s+)?([^)]+?)\\s*(\\))\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.vertex" },
            "2": { "name": "punctuation.definition.parameters.begin.vertex" },
            "3": { "name": "variable.parameter.receiver.vertex" },
            "4": { "name": "punctuation.separator.type.vertex" },
            "5": { "name": "storage.modifier.mut.vertex" },
            "6": { "name": "entity.name.type.vertex" },
            "7": { "name": "punctuation.definition.parameters.end.vertex" },
            "8": { "name": "entity.name.function.vertex" }
          }
        },
        {
          "comment": "Named function — func foo",
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.function.vertex" },
            "2": { "name": "entity.name.function.vertex"         }
          }
        },
        {
          "comment": "Struct or class declaration",
          "match": "\\b(struct|class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.vertex" },
            "2": { "name": "entity.name.type.vertex"         }
          }
        },
        {
          "comment": "Enum declaration",
          "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.vertex" },
            "2": { "name": "entity.name.enum.vertex"         }
          }
        },
        {
          "comment": "Type alias — type FILE = any opaque",
          "match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.type.vertex" },
            "2": { "name": "entity.name.type.vertex"         }
          }
        },
        {
          "comment": "Package declaration",
          "match": "\\b(package)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.control.import.vertex"   },
            "2": { "name": "entity.name.namespace.vertex"    }
          }
        }
      ]
    },

    "postfix-intrinsics": {
      "comment": "Language-defined postfix intrinsics — always follow a dot. Matched before keywords to avoid the .any() vs any-type ambiguity.",
      "patterns": [
        {
          "comment": "Execution postfixes: .await()  .spawn()  .dispatch()  .fork()",
          "name": "support.function.builtin.execution.vertex",
          "match": "\\.(await|spawn|dispatch|fork)(?=\\s*\\()"
        },
        {
          "comment": "Lifetime postfixes: .new()  .delete()",
          "name": "support.function.builtin.lifetime.vertex",
          "match": "\\.(new|delete)(?=\\s*\\()"
        },
        {
          "comment": "Error propagation: .try()",
          "name": "support.function.builtin.result.vertex",
          "match": "\\.try(?=\\s*\\()"
        },
        {
          "comment": "Raw-pointer escape: .any()",
          "name": "support.function.builtin.pointer.vertex",
          "match": "\\.any(?=\\s*\\()"
        },
        {
          "comment": "Channel construction: .channel()",
          "name": "support.function.builtin.channel.vertex",
          "match": "\\.channel(?=\\s*\\()"
        },
        {
          "comment": "Type intrinsics: .sizeof()  .alignof()  .byteSize()",
          "name": "support.function.builtin.type.vertex",
          "match": "\\.(sizeof|alignof|byteSize)(?=\\s*\\()"
        }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "comment": "Control flow",
          "name": "keyword.control.vertex",
          "match": "\\b(break|case|continue|default|defer|else|fallthrough|for|if|in|return|switch|while)\\b"
        },
        {
          "comment": "Storage keywords — binding kind",
          "name": "storage.type.vertex",
          "match": "\\b(let|var)\\b"
        },
        {
          "comment": "Storage modifiers — weak (ref counting), shared (gpu)",
          "name": "storage.modifier.vertex",
          "match": "\\b(weak|shared)\\b"
        },
        {
          "comment": "Execution qualifiers — sit between param list and return arrow",
          "name": "keyword.other.qualifier.vertex",
          "match": "\\b(async|thread|process|gpu)\\b"
        },
        {
          "comment": "Mutability modifier",
          "name": "storage.modifier.mut.vertex",
          "match": "\\bmut\\b"
        },
        {
          "comment": "Import path declaration",
          "name": "keyword.control.import.vertex",
          "match": "\\b(import|build)\\b"
        },
        {
          "comment": "Declaration keywords when not followed by a name (anon func, func type, etc.)",
          "name": "keyword.declaration.vertex",
          "match": "\\b(func|struct|class|enum|type|package)\\b"
        }
      ]
    },

    "primitive-types": {
      "comment": "Built-in primitive types — ordered longest to shortest to avoid partial matches",
      "name": "support.type.primitive.vertex",
      "match": "\\b(uint8|uint16|uint32|uint64|int8|int16|int32|int64|uint|int|float|double|bool|string|char|void)\\b"
    },

    "special-types": {
      "patterns": [
        {
          "comment": "Channel type annotation keyword (§41)",
          "name": "support.type.channel.vertex",
          "match": "\\bchan\\b"
        },
        {
          "comment": "Pointer / FFI type keywords",
          "name": "support.type.pointer.vertex",
          "match": "\\b(any|opaque)\\b"
        },
        {
          "comment": "Result type",
          "name": "support.type.result.vertex",
          "match": "\\bResult\\b"
        },
        {
          "comment": "Ok / Err variant labels",
          "name": "support.constant.result.vertex",
          "match": "\\b(Ok|Err)\\b"
        }
      ]
    },

    "operators": {
      "comment": "Longer / higher-precedence tokens must appear before any shorter prefix they share.",
      "patterns": [
        {
          "comment": "Identity equality (§14) — must precede ==  !=",
          "name": "keyword.operator.identity.vertex",
          "match": "===|!=="
        },
        {
          "comment": "Overflow arithmetic (§8) — must precede &  +  -  *",
          "name": "keyword.operator.overflow.vertex",
          "match": "&\\+|&-|&\\*"
        },
        {
          "comment": "Compound assignment (§6) — must precede =  +  -  * /  %",
          "name": "keyword.operator.assignment.compound.vertex",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "comment": "Logical AND / OR (§10) — must precede &  |",
          "name": "keyword.operator.logical.vertex",
          "match": "&&|\\|\\|"
        },
        {
          "comment": "Nil-coalescing (§13) — must precede ?",
          "name": "keyword.operator.nil-coalescing.vertex",
          "match": "\\?\\?"
        },
        {
          "comment": "Equality (§9) — must precede = and !",
          "name": "keyword.operator.comparison.vertex",
          "match": "==|!="
        },
        {
          "comment": "Ordered comparison with equals (§9) — must precede > and <",
          "name": "keyword.operator.comparison.vertex",
          "match": ">=|<="
        },
        {
          "comment": "Bit-shift (§7) — must precede < and >",
          "name": "keyword.operator.bitwise.shift.vertex",
          "match": "<<|>>"
        },
        {
          "comment": "Range operators (§11) — ..<  and  ...",
          "name": "keyword.operator.range.vertex",
          "match": "\\.\\.<|\\.\\.\\.(?![a-zA-Z_])"
        },
        {
          "comment": "Return-type arrow — must precede -",
          "name": "keyword.operator.arrow.vertex",
          "match": "->"
        },
        {
          "comment": "Ordered comparison singles",
          "name": "keyword.operator.comparison.vertex",
          "match": "[<>]"
        },
        {
          "comment": "Logical NOT",
          "name": "keyword.operator.logical.not.vertex",
          "match": "!"
        },
        {
          "comment": "Bitwise AND / address-of prefix (&var)",
          "name": "keyword.operator.bitwise.vertex",
          "match": "&"
        },
        {
          "comment": "Bitwise OR  XOR  NOT",
          "name": "keyword.operator.bitwise.vertex",
          "match": "[|^~]"
        },
        {
          "comment": "Arithmetic",
          "name": "keyword.operator.arithmetic.vertex",
          "match": "[+\\-*/%]"
        },
        {
          "comment": "Assignment — matched last so compound forms are not re-matched",
          "name": "keyword.operator.assignment.vertex",
          "match": "="
        },
        {
          "comment": "Optional / ternary condition marker",
          "name": "keyword.operator.optional.vertex",
          "match": "\\?"
        }
      ]
    }

  }
}