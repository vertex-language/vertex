{
  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{",  "close": "}",  "notIn": ["string", "comment"] },
    { "open": "[",  "close": "]",  "notIn": ["string", "comment"] },
    { "open": "(",  "close": ")",  "notIn": ["string", "comment"] },
    { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
    { "open": "`",  "close": "`",  "notIn": ["string", "comment"] },
    { "open": "/*", "close": " */","notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["`", "`"]
  ],
  "indentationRules": {
    "increaseIndentPattern": "\\{\\s*$",
    "decreaseIndentPattern": "^\\s*\\}"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*/\\*",
      "afterText":  "\\*/\\s*$",
      "action": { "indent": "indentOutdent", "appendText": " * " }
    },
    {
      "beforeText": "^\\s* \\*[^/]",
      "action": { "indent": "none", "appendText": "* " }
    }
  ],
  "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*"
}